---
title: "Franchise — Yellow Bee"
description: "Bring Yellow Bee to your community. Inquire about franchising opportunities."
permalink: /franchise/index.html
tickerItems:
  - "Franchise Inquiries Now Open"
  - "Apply Today"
---

{% extends "base.njk" %}

{% block head_extra %}
<link rel="stylesheet" href="/assets/css/page-franchise.css?v={{ buildHash }}">
{% endblock %}

{% block content %}

<section class="form-section form-section--standalone" id="inquiry-form">
  <div class="fr-sec">
    <div class="form-layout">

      <div class="form-intro reveal-left">
        <div class="fr-eyebrow eye-yellow">Get Started</div>
        <h2>Ready to build something?</h2>
        <p>Tell us about yourself and your market. There's no commitment to submitting an inquiry &mdash; just a conversation to see if we're a fit.</p>
        <p>We typically respond within 3&ndash;5 business days.</p>

        <div class="form-contact-info">
          <div class="form-contact-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>
            <span><a href="mailto:{{ site.email }}">{{ site.email }}</a></span>
          </div>
          <div class="form-contact-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>{{ site.address.street }}, {{ site.address.city }}, {{ site.address.state }} {{ site.address.zip }}</span>
          </div>
          <div class="form-contact-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 016.19 15a19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            <span><a href="tel:{{ site.phone | replace(' ', '') | replace('(', '') | replace(')', '') | replace('-', '') }}">{{ site.phone }}</a></span>
          </div>
        </div>
      </div>

      <div class="inquiry-form reveal-right">
        <form id="franchiseForm" onsubmit="handleFranchiseSubmit(event)">
          <div class="form-row">
            <div class="form-group">
              <label for="fname">First Name *</label>
              <input type="text" id="fname" name="fname" placeholder="Jane" required>
            </div>
            <div class="form-group">
              <label for="lname">Last Name *</label>
              <input type="text" id="lname" name="lname" placeholder="Smith" required>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="email">Email Address *</label>
              <input type="email" id="email" name="email" placeholder="jane@example.com" required>
            </div>
            <div class="form-group">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" name="phone" placeholder="(206) 555-0000">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="city">City / Market of Interest *</label>
              <input type="text" id="city" name="city" placeholder="e.g. Portland, OR" required>
            </div>
            <div class="form-group">
              <label for="timeline">Desired Timeline</label>
              <select id="timeline" name="timeline">
                <option value="">Select a timeframe</option>
                <option value="asap">As soon as possible</option>
                <option value="6mo">Within 6 months</option>
                <option value="1yr">Within 1 year</option>
                <option value="2yr">1&ndash;2 years</option>
                <option value="exploring">Just exploring</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label for="background">Your Background *</label>
            <select id="background" name="background" required>
              <option value="">Select your experience</option>
              <option value="food">Food &amp; Beverage / Restaurant Industry</option>
              <option value="retail">Retail / Convenience Store Operations</option>
              <option value="business">General Business / Entrepreneurship</option>
              <option value="franchise">Previous Franchise Owner</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="investment">Investment Capacity</label>
            <select id="investment" name="investment">
              <option value="">Select a range</option>
              <option value="under150">Under $150K</option>
              <option value="150-250">$150K &ndash; $250K</option>
              <option value="250-350">$250K &ndash; $350K</option>
              <option value="over350">$350K+</option>
              <option value="unsure">Not sure yet</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">Tell Us About Yourself &amp; Your Goals</label>
            <textarea id="message" name="message" placeholder="Share your background, why you're interested in Yellow Bee, and what market you have in mind..."></textarea>
          </div>
          <div class="form-check">
            <input type="checkbox" id="consent" name="consent" required>
            <label for="consent">I agree to be contacted by Yellow Bee regarding this franchise inquiry. I understand this is not a commitment or offer to purchase a franchise. View our <a href="/contact/">privacy policy</a>.</label>
          </div>
          <button type="submit" class="form-submit-btn">Submit Franchise Inquiry &rarr;</button>
          <p class="form-note">We review every inquiry personally and respond within 3&ndash;5 business days. Your information is never shared with third parties.</p>
        </form>
      </div>

    </div>
  </div>
</section>

{% endblock %}

{% block scripts %}
<script>
// Build a mailto: that opens the user's email client pre-filled with their
// inquiry, addressed to {{ site.email }}. No backend service required.
function handleFranchiseSubmit(e) {
  e.preventDefault();
  const f = e.target;
  const v = id => (f.querySelector('#' + id) || {}).value || '';
  const labelMap = {
    asap: 'As soon as possible', '6mo': 'Within 6 months', '1yr': 'Within 1 year',
    '2yr': '1–2 years', exploring: 'Just exploring',
    food: 'Food & Beverage / Restaurant Industry',
    retail: 'Retail / Convenience Store Operations',
    business: 'General Business / Entrepreneurship',
    franchise: 'Previous Franchise Owner', other: 'Other',
    under150: 'Under $150K', '150-250': '$150K – $250K',
    '250-350': '$250K – $350K', over350: '$350K+', unsure: 'Not sure yet',
  };
  const fields = [
    ['Name', v('fname') + ' ' + v('lname')],
    ['Email', v('email')],
    ['Phone', v('phone')],
    ['City / Market', v('city')],
    ['Timeline', labelMap[v('timeline')] || v('timeline')],
    ['Background', labelMap[v('background')] || v('background')],
    ['Investment Capacity', labelMap[v('investment')] || v('investment')],
    ['', ''],
    ['Message', v('message')],
  ];
  const body = fields.map(([k, val]) => k ? (k + ': ' + val) : '').join('\n');
  const subject = 'Yellow Bee Franchise Inquiry — ' + v('fname') + ' ' + v('lname');
  const url = 'mailto:{{ site.email }}'
    + '?subject=' + encodeURIComponent(subject)
    + '&body=' + encodeURIComponent(body);
  window.location.href = url;

  const btn = f.querySelector('.form-submit-btn');
  btn.textContent = '✓ Email opened — send to complete';
  btn.style.background = '#4AA84A';
  setTimeout(() => {
    btn.textContent = 'Submit Franchise Inquiry →';
    btn.style.background = '';
  }, 6000);
}
</script>
{% endblock %}
