{#
  Live promo banner. Renders only when there's an active promotion in the Apnosh
  portal (apnosh.activePromo is non-null and the current date is in the valid window).

  Hide this include from base.njk if you want to position it elsewhere or style differently.
#}
{% if apnosh.activePromo %}
<div class="apnosh-promo-banner" style="
  background: {{ apnosh.brand.primary_color or '#000' }};
  color: white;
  padding: 12px 24px;
  text-align: center;
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 600;
  font-size: 14px;
  letter-spacing: 0.02em;
">
  <span style="opacity: 0.85; margin-right: 12px; text-transform: uppercase; font-size: 11px; letter-spacing: 0.1em;">Now on</span>
  <strong>{{ apnosh.activePromo.name }}</strong>
  {% if apnosh.activePromo.description %}
    <span style="margin-left: 12px; opacity: 0.9;">— {{ apnosh.activePromo.description }}</span>
  {% endif %}
  {% if apnosh.activePromo.code %}
    <span style="margin-left: 12px; padding: 2px 8px; border: 1px solid rgba(255,255,255,0.4); border-radius: 4px; font-family: 'JetBrains Mono', monospace;">{{ apnosh.activePromo.code }}</span>
  {% endif %}
</div>
{% endif %}
