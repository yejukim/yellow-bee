{% import "socials-svg.njk" as icons %}
<footer class="footer">
  <div class="footer-topline" aria-hidden="true"></div>
  <div class="footer-grid">
    <div class="footer-brand">
      <img src="/photos/horizontallogo.png" alt="{{ site.name }}">
      <p>Fresh food. Fast service. No compromise. Your neighborhood market in the heart of Seattle.</p>
      <div class="footer-social">
        <a href="{{ site.socials.instagram }}" aria-label="Instagram">{{ icons.instagram() }}</a>
        <a href="{{ site.socials.facebook }}" aria-label="Facebook">{{ icons.facebook() }}</a>
        <a href="{{ site.socials.tiktok }}" aria-label="TikTok">{{ icons.tiktok() }}</a>
        <a href="{{ site.socials.x }}" aria-label="X">{{ icons.x() }}</a>
      </div>
    </div>
    {% for groupLabel, items in site.footerNav %}
    <div class="footer-col">
      <h4>{{ groupLabel }}</h4>
      <ul>
        {% for item in items %}
        <li><a href="{{ item.href }}">{{ item.label }}</a></li>
        {% endfor %}
      </ul>
    </div>
    {% endfor %}
    <div class="footer-col">
      <h4>Contact</h4>
      <div class="info-line">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.45)" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        {{ site.address.street }}<br>{{ site.address.city }}, {{ site.address.state }} {{ site.address.zip }}
      </div>
      <div class="info-line">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.45)" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        {{ site.phone }}
      </div>
      <div class="info-line">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.45)" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>
        {{ site.email }}
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <span>&copy; 2026 {{ site.name }} Market. All rights reserved.</span>
    <span>{{ site.tagline }}.</span>
  </div>
</footer>
