---
title: "Menu — Yellow Bee"
description: "Fresh banh mi, handcrafted boba, bagels baked daily, and sweet pastries. Made to order at Yellow Bee."
permalink: /menu/index.html
tickerItems:
  - "Menu · Made to Order Daily"
  - "$10 Banh Mi"
  - "Bagels Baked Fresh"
  - "Seasonal Boba"
  - "Danish · Cookies · Pastries"
---

{% extends "base.njk" %}

{% block head_extra %}
<link rel="stylesheet" href="/assets/css/page-menu.css?v={{ buildHash }}">
{% endblock %}

{% block content %}

<!-- SEASONAL DROP -->
<section class="menu-section menu-section--paper menu-seasonal menu-section--first" id="seasonal">
  <div class="menu-section-mega menu-section-mega--dark" aria-hidden="true">Season</div>
  <div class="sec-container">
    {% for item in seasonal.items %}
    <div class="seasonal-feature reveal">
      <figure class="seasonal-poster">
        <img src="/{{ item.poster }}" alt="{{ item.name }} — {{ item.season }}" loading="lazy">
        <figcaption class="seasonal-poster-cap">{{ item.season }}</figcaption>
      </figure>

      <div class="seasonal-body">
        <div class="seasonal-eyebrow">{{ seasonal.eyebrow }}</div>
        <h2 class="seasonal-name">{{ item.name }}.</h2>
        <p class="seasonal-tagline">{{ item.tagline }}</p>
        <p class="seasonal-desc">{{ item.description }}</p>

        <dl class="seasonal-spec">
          <dt>Price</dt>
          <dd>${{ item.price }}</dd>
          <dt>{{ item.addOn.label }}</dt>
          <dd>{{ item.addOn.price }}</dd>
          <dt>Window</dt>
          <dd>{{ item.available }}</dd>
        </dl>

        <div class="seasonal-ctas">
          <a href="#drinks-menu" class="btn btn-yellow">See Full Drinks</a>
          <a href="/locations/" class="btn btn-outline-dark">Find A Store</a>
        </div>
      </div>
    </div>
    {% endfor %}
  </div>
</section>

<!--
  BANH MI -- now driven by Apnosh's menu_items table.

  The Banh Mi list and prices come from apnosh.menu['Banh Mi'] (managed in
  the Apnosh portal at /dashboard/website/manage). Yellow Bee staff can
  edit any price, add a new item, mark featured -- changes show up here
  on the next build.

  Photos and descriptions are still pulled from the local _data/menu.json
  by name match where available (gives existing items their rich card
  treatment). New API items render as a clean name+price tile.
-->
<section class="menu-section menu-section--dark" id="banh-mi">
  <div class="menu-section-mega" aria-hidden="true">Banh Mi</div>
  <div class="sec-container">
    <header class="menu-section-head reveal">
      <div class="sec-mark">Chapter 02 / {{ menu.banhmi.label }}</div>
      <h2>{{ menu.banhmi.headline }}</h2>
      <p class="menu-section-meta">{{ menu.banhmi.meta }}</p>
    </header>

    {# Text-only treatment for the full Banh Mi list. Keeps descriptions
       and prices but drops photos -- cleaner showcase since stock photos
       can mislead and real photos aren't always available. #}
    <div class="menu-grid menu-grid--text">
      {% if apnosh.menu and apnosh.menu['Banh Mi'] %}
        {% for item in apnosh.menu['Banh Mi'].items %}
          {%- set legacy = (menu.banhmi.items | selectattr('name', 'equalto', item.name) | first)
              or (menu.banhmi.items | selectattr('name', 'equalto', item.name | replace('The ', '')) | first) -%}
          <article class="menu-card menu-card--text reveal d{{ loop.index }}" data-num="№ 0{{ loop.index }}">
            <div class="menu-card-body">
              <div class="menu-card-head">
                <h3 class="menu-card-name">{{ item.name }}</h3>
                <span class="menu-card-price">{{ item.price }}</span>
              </div>
              {% if item.description or (legacy and legacy.desc) %}
              <p class="menu-card-desc">{{ item.description or legacy.desc }}</p>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      {% else %}
        {% for item in menu.banhmi.items %}
        <article class="menu-card menu-card--text reveal d{{ loop.index }}" data-num="№ 0{{ loop.index }}">
          <div class="menu-card-body">
            <div class="menu-card-head">
              <h3 class="menu-card-name">{{ item.name }}</h3>
              <span class="menu-card-price">{{ item.price }}</span>
            </div>
            <p class="menu-card-desc">{{ item.desc }}</p>
          </div>
        </article>
        {% endfor %}
      {% endif %}
    </div>

    {# SAUCES -- modifiers under Banh Mi, rendered inline so it visually
       belongs to this section (mirrors the Toppings treatment under Boba). #}
    {% if apnosh.menu and apnosh.menu['Sauces'] and apnosh.menu['Sauces'].modifiers.length > 0 %}
    <div class="menu-toppings reveal" style="margin-top:1.5rem;" id="sauces">
      <div class="menu-toppings-head">
        <div class="menu-toppings-label">Sauce options</div>
        <div class="menu-toppings-price">House made</div>
      </div>
      <div class="menu-toppings-list">
        {% for s in apnosh.menu['Sauces'].modifiers %}
        <span class="menu-topping-tag">
          {{ s.name }}{% if s.price %} <em style="opacity:.7">({{ s.price }})</em>{% endif %}
        </span>
        {% endfor %}
      </div>
    </div>
    {% endif %}
  </div>
</section>

<!-- BAGELS -- "Make It a Bagel Banh Mi". Bread choices come from
     apnosh.menu['Bagel options'] (modifiers). Yellow Bee staff add new
     bagel types in the dashboard. -->
<section class="menu-section menu-section--paper" id="bagels">
  <div class="menu-section-mega menu-section-mega--dark" aria-hidden="true">Bagels</div>
  <div class="sec-container">
    <header class="menu-section-head reveal">
      <div class="sec-mark sec-mark--dark">Chapter 03 / {{ menu.bagels.label }}</div>
      <h2>Make it a Bagel Banh Mi.</h2>
      <p class="menu-section-meta menu-section-meta--dark"><em>Same price as banh mi.</em></p>
    </header>

    <ul class="menu-list reveal">
      {% if apnosh.menu and apnosh.menu['Bagel options'] %}
        {% for item in apnosh.menu['Bagel options'].modifiers %}
        <li class="menu-list-item">
          <span class="menu-list-name">{{ item.name }}</span>
          <span class="menu-list-dots" aria-hidden="true"></span>
          <span class="menu-list-price">same as banh mi</span>
        </li>
        {% endfor %}
      {% else %}
        {% for item in menu.bagels.items %}
        <li class="menu-list-item">
          <span class="menu-list-name">{{ item.name }}</span>
          <span class="menu-list-dots" aria-hidden="true"></span>
          <span class="menu-list-price">{{ menu.bagels.price }}</span>
        </li>
        {% endfor %}
      {% endif %}
    </ul>
  </div>
</section>

<!--
  BOBA (formerly "Seasonal Boba" -- renamed per change-request PDF).
  Drinks come from apnosh.menu['Boba'].items. Yellow Bee staff add new
  drinks in the dashboard. Photos still come from local _data/drinks.json
  by name match where available; new drinks render as clean name+price tiles.
  Toppings come from apnosh.menu['Toppings'].modifiers.
-->
<section class="menu-section menu-section--dark" id="drinks-menu">
  <div class="menu-section-mega" aria-hidden="true">Sip</div>
  <div class="sec-container">
    <header class="menu-section-head reveal">
      <div class="sec-mark">Chapter 04 / The Bar</div>
      <h2>Boba.</h2>
      <p class="menu-section-meta">Handcrafted milk teas, fruit teas, and smoothies.</p>
    </header>

    {% if apnosh.menu and apnosh.menu['Boba'] %}
      {# Split into two groups: items with portal photos get the card grid;
         everything else gets a clean dotted-line list. Per Yellow Bee PDF
         "you don't need to add photos for all the drinks, just some". #}
      {%- set bobaWithPhotos = apnosh.menu['Boba'].items | selectattr('photoUrl') | list -%}
      {%- set bobaWithoutPhotos = [] -%}
      {%- for item in apnosh.menu['Boba'].items -%}
        {%- if not item.photoUrl -%}
          {%- set bobaWithoutPhotos = bobaWithoutPhotos.concat([item]) -%}
        {%- endif -%}
      {%- endfor -%}

      {% if bobaWithPhotos.length > 0 %}
      <div class="menu-drinks-grid menu-drinks-grid--featured">
        {% for item in bobaWithPhotos %}
        <article class="drink-menu-card reveal d{{ loop.index }}">
          <div class="drink-menu-card-img">
            <img src="{{ item.photoUrl }}" alt="{{ item.name }}" loading="lazy">
          </div>
          <div class="drink-menu-card-name">{{ item.name }}</div>
          <div class="drink-menu-card-price">{{ item.price }}</div>
        </article>
        {% endfor %}
      </div>
      {% endif %}

      {% if bobaWithoutPhotos.length > 0 %}
      <ul class="menu-list menu-list--dark reveal" style="margin-top:{% if bobaWithPhotos.length > 0 %}2.5rem{% else %}0{% endif %};">
        {% for item in bobaWithoutPhotos %}
        <li class="menu-list-item">
          <span class="menu-list-name">{{ item.name }}</span>
          <span class="menu-list-dots" aria-hidden="true"></span>
          <span class="menu-list-price">{{ item.price }}</span>
        </li>
        {% endfor %}
      </ul>
      {% endif %}
    {% else %}
      <div class="menu-drinks-grid">
        {% for drink in drinks.items %}
        <article class="drink-menu-card reveal d{{ loop.index }}">
          <div class="drink-menu-card-img">
            <img src="/{{ drink.image }}" alt="{{ drink.alt }}" loading="lazy">
          </div>
          <div class="drink-menu-card-name">{{ drink.name }}</div>
          <div class="drink-menu-card-price">{{ drink.price }}</div>
        </article>
        {% endfor %}
      </div>
    {% endif %}

    {% if apnosh.menu and apnosh.menu['Toppings'] and apnosh.menu['Toppings'].modifiers.length > 0 %}
    <div class="menu-toppings reveal">
      <div class="menu-toppings-head">
        <div class="menu-toppings-label">Toppings</div>
        <div class="menu-toppings-price">House-made</div>
      </div>
      <div class="menu-toppings-list">
        {% for t in apnosh.menu['Toppings'].modifiers %}
        <span class="menu-topping-tag">{{ t.name }}{% if t.price %} <em style="opacity:.7">({{ t.price }})</em>{% endif %}</span>
        {% endfor %}
      </div>
    </div>
    {% else %}
    <div class="menu-toppings reveal">
      <div class="menu-toppings-head">
        <div class="menu-toppings-label">{{ drinks.toppings.label }}</div>
        <div class="menu-toppings-price">{{ drinks.toppings.price }}</div>
      </div>
      <div class="menu-toppings-list">
        {% for t in drinks.toppings.list %}
        <span class="menu-topping-tag">{{ t }}</span>
        {% endfor %}
      </div>
    </div>
    {% endif %}
  </div>
</section>

<!--
  ESPRESSO -- new section per change-request PDF. Items from
  apnosh.menu['Espresso']. Featured items (currently Pandan Matcha
  Delight) get a highlight treatment. Milk options from
  apnosh.menu['Milk options'].modifiers.
-->
{% if apnosh.menu and apnosh.menu['Espresso'] and apnosh.menu['Espresso'].items.length > 0 %}
<section class="menu-section menu-section--paper" id="espresso">
  <div class="menu-section-mega menu-section-mega--dark" aria-hidden="true">Espresso</div>
  <div class="sec-container">
    <header class="menu-section-head reveal">
      <div class="sec-mark sec-mark--dark">Chapter 05 / The Roast</div>
      <h2>Coffee &amp; Espresso.</h2>
      <p class="menu-section-meta menu-section-meta--dark">All available in hot, iced, or blended.</p>
    </header>

    {% set featuredEspresso = apnosh.menu['Espresso'].items | selectattr('isFeatured') | first %}
    {% if featuredEspresso %}
    <article class="seasonal-feature reveal" style="margin-bottom:2.5rem;">
      {% if featuredEspresso.photoUrl %}
      <figure class="seasonal-poster">
        <span class="seasonal-poster-cap">Featured</span>
        <img src="{{ featuredEspresso.photoUrl }}" alt="{{ featuredEspresso.name }}" loading="lazy">
      </figure>
      {% endif %}
      <div class="seasonal-body">
        {% if not featuredEspresso.photoUrl %}<div class="seasonal-eyebrow">Featured</div>{% endif %}
        <h2 class="seasonal-name">{{ featuredEspresso.name }}.</h2>
        <p class="seasonal-tagline">{{ featuredEspresso.description or "Our signature drink." }}</p>
        <dl class="seasonal-spec">
          <dt>Price</dt>
          <dd>{{ featuredEspresso.price }}</dd>
        </dl>
      </div>
    </article>
    {% endif %}

    <ul class="menu-list reveal">
      {% for item in apnosh.menu['Espresso'].items %}
        {% if not item.isFeatured %}
        <li class="menu-list-item">
          <span class="menu-list-name">{{ item.name }}</span>
          <span class="menu-list-dots" aria-hidden="true"></span>
          <span class="menu-list-price">{{ item.price }}</span>
        </li>
        {% endif %}
      {% endfor %}
    </ul>

    {% if apnosh.menu['Milk options'] and apnosh.menu['Milk options'].modifiers.length > 0 %}
    <div class="menu-toppings reveal" style="margin-top:1.5rem;">
      <div class="menu-toppings-head">
        <div class="menu-toppings-label">Milk options</div>
        <div class="menu-toppings-price">No surcharge</div>
      </div>
      <div class="menu-toppings-list">
        {% for m in apnosh.menu['Milk options'].modifiers %}
        <span class="menu-topping-tag">{{ m.name }}</span>
        {% endfor %}
      </div>
    </div>
    {% endif %}
  </div>
</section>
{% endif %}

<!-- PASTRIES -->
<section class="menu-section menu-section--paper" id="pastries">
  <div class="menu-section-mega menu-section-mega--dark" aria-hidden="true">Sweet</div>
  <div class="sec-container">
    <header class="menu-section-head reveal">
      <div class="sec-mark sec-mark--dark">Chapter 05 / {{ menu.pastries.label }}</div>
      <h2>{{ menu.pastries.headline }}</h2>
      <p class="menu-section-meta menu-section-meta--dark">{{ menu.pastries.meta }}</p>
    </header>

    <div class="menu-pastries-grid">
      {% for item in menu.pastries.items %}
      <article class="pastry-card reveal d{{ loop.index }}">
        <div class="pastry-card-head">
          <h3 class="pastry-card-name">{{ item.name }}</h3>
          <span class="pastry-card-price">{{ item.price }}</span>
        </div>
        <p class="pastry-card-desc">{{ item.desc }}</p>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

{% endblock %}
